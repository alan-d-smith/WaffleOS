# Bochs configuration for WaffleOS.
#
# Run with `make bochs`, which uses tools/run-bochs.sh to auto-detect and
# override romimage/vgaromimage/display_library for your system (distro package
# or source build, Linux or WSL). The values below are the Debian/Ubuntu/WSL
# defaults, so `bochs -f .bochsrc -q` also works directly on those systems
# (after: sudo apt install bochs bochs-sdl vgabios).
megs: 32  # Memory size in Megabytes
cpu: count=1, ips=5000000
vga: extension=vbe
romimage: file=/usr/share/seabios/bios-256k.bin
vgaromimage: file=/usr/share/bochs/VGABIOS-lgpl-latest
boot: floppy  # Boot from floppy
floppya: 1_44=build/main_floppy.img, status=inserted
log: build/bochs.log
clock: sync=none, time0=local, rtc_sync=0
mouse: type=ps2, enabled=1
display_library: sdl2